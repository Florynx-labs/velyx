{
  "name": "vscode-velyx",
  "displayName": "VELYX — .vx Language Support",
  "description": "Official VS Code extension for VELYX .vx Single-File Components. Syntax highlighting, file icons, snippets and hover information for the VELYX compiler-first reactive framework.",
  "version": "0.4.0",
  "publisher": "florynx-labs",
  "icon": "icon.png",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Florynx-labs/velyx"
  },
  "homepage": "https://velyx.dev",
  "keywords": ["velyx", "vx", "frontend", "reactive", "compiler", "signals", "florynx"],
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Themes"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:velyx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "velyx",
        "aliases": ["VELYX", "velyx"],
        "extensions": [".vx"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "velyx",
        "scopeName": "source.velyx",
        "path": "./syntaxes/velyx.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "velyx",
        "path": "./snippets/velyx.json"
      }
    ],
    "iconThemes": [
      {
        "id": "velyx-file-icons",
        "label": "VELYX File Icons",
        "path": "./themes/velyx-file-icons.json"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p .",
    "build": "tsc -p .",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.80.0",
    "@vscode/vsce": "^3.3.2",
    "typescript": "^5.4.5"
  }
}
