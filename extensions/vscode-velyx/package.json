{
  "name": "vscode-velyx",
  "displayName": "VELYX Language Support & Diagnostics",
  "description": "Official VS Code Extension for VELYX .vx Single-File Components — Syntax Highlighting, Snippets, Live Diagnostics and .vx File Icons.",
  "version": "0.4.0",
  "publisher": "florynx-labs",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters",
    "Themes"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:velyx"
  ],
  "contributes": {
    "languages": [
      {
        "id": "velyx",
        "aliases": ["VELYX", "velyx"],
        "extensions": [".vx"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "velyx",
        "scopeName": "source.velyx",
        "path": "./syntaxes/velyx.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "velyx",
        "path": "./snippets/velyx.json"
      }
    ],
    "iconThemes": [
      {
        "id": "velyx-file-icons",
        "label": "VELYX File Icons",
        "path": "./themes/velyx-file-icons.json"
      }
    ]
  },
  "scripts": {
    "build": "tsc -p ."
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@types/vscode": "^1.80.0",
    "typescript": "^5.4.5"
  }
}
